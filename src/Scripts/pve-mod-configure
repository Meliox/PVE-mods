#!/usr/bin/env bash
#
# pve-mod-configure - Interactive configuration tool for pve-mod
# Detects hardware, asks the user which features to enable, writes
# /etc/pve-mod/pve-mod.conf, and applies patches to PVE system files.
#
# Module-specific logic lives in /usr/lib/pve-mod/configure.d/<mod>.sh,
# sourced at startup. Each module file provides the standard four-function
# API: <mod>_defaults, <mod>_load_conf, <mod>_configure, <mod>_write_conf.

set -euo pipefail

CONF_FILE="/etc/pve-mod/pve-mod.conf"
CONFD_DIR="/etc/pve-mod/conf.d"
APPLY_PATCHES="/usr/lib/pve-mod/apply-patches.sh"
REVERT_PATCHES="/usr/lib/pve-mod/revert-patches.sh"
NODES_PM="/usr/share/perl5/PVE/API2/Nodes.pm"

#region helpers
msgb() { echo -e "\e[1m${1}\e[0m"; }
info() { echo -e "\e[0;32m[info] ${1}\e[0m"; }
warn() { echo -e "\e[0;33m[warning] ${1}\e[0m"; }
err()  { echo -e "\e[0;31m[error] ${1}\e[0m"; exit 1; }
ask()  {
    local prompt="$1" response
    read -r -p $'\n\e[1;36m'"${prompt}:"$'\e[0m ' response
    echo "$response"
}
bool() { [[ "$1" == true ]] && echo 1 || echo 0; }
mod_status() {
    local val="$1" on_label="${2:-[enabled]}" off_label="${3:-[disabled]}"
    [[ "$val" == "1" ]] && echo -e "\e[0;32m${on_label}\e[0m" || echo -e "\e[0;33m${off_label}\e[0m"
}
#endregion helpers

# Source all module configure scripts. Override CONFIGURE_D_DIR for testing.
CONFIGURE_D_DIR="${PVE_MOD_CONFIGURE_D:-/usr/lib/pve-mod/configure.d}"
for _f in "${CONFIGURE_D_DIR}"/*.sh; do
    [[ -f "$_f" ]] || continue
    # shellcheck source=/dev/null
    source "$_f"
done; unset _f

_load_main_conf() {
    [[ -f "$CONF_FILE" ]] || return 0
    local section="" line key val
    while IFS= read -r line; do
        case "$line" in
            '#'*|'') continue ;;
            '['*']') section="${line#[}"; section="${section%]}"; continue ;;
        esac
        [[ "$line" == *=* ]] || continue
        key="${line%%=*}"; val="${line#*=}"
        case "${section}.${key}" in
            modules.node_info)    MOD_NODE_INFO="$val" ;;
            modules.nag_screen)   MOD_NAG_SCREEN="$val" ;;
            pve_trigger.enabled)  PVE_TRIGGER_ENABLED="$val" ;;
        esac
    done < "$CONF_FILE"
}

write_main_conf() {
    mkdir -p "$(dirname "$CONF_FILE")" "$CONFD_DIR"
    cat > "$CONF_FILE" <<EOF
# pve-mod main configuration file
# Managed by pve-mod-configure. Re-run to update.
#
# This file only declares which mods are enabled. Each mod keeps its own
# settings in ${CONFD_DIR}/<mod>.conf

[modules]
node_info=${MOD_NODE_INFO}
nag_screen=${MOD_NAG_SCREEN}

[pve_trigger]
enabled=${PVE_TRIGGER_ENABLED}
EOF
    info "Main configuration saved to $CONF_FILE"
}

main() {
    # в”Җв”Җ Welcome banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    local _version
    _version=$(dpkg-query -W -f='${Version}' pve-mod 2>/dev/null || echo "unknown")
    echo -e "\e[1;34m"
    echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—    в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
    echo "  в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ    в–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ"
    echo "  в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—      в–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—"
    echo "  в–Ҳв–Ҳв•”в•җв•җв•җв•қ в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•қ      в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘"
    echo "  в–Ҳв–Ҳв•‘      в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—    в–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘"
    echo "  в•ҡв•җв•қ       в•ҡв•җв•җв•җв•қ  в•ҡв•җв•җв•җв•җв•җв•җв•қ    в•ҡв•җв•қ     в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•җв•җв•җв•җв•җв•қ"
    echo -e "\e[0m"
    echo -e "\e[1m  PVE-mods Configurator  \e[0;36mv${_version}\e[0m"
    echo -e "  Proxmox VE enhancement suite вҖ” hardware monitoring, GPU info & more\n"

    # в”Җв”Җ Root check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    [[ $EUID -eq 0 ]] || err "This script must be run as root."

    # в”Җв”Җ Prerequisite check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if [[ ! -x "$APPLY_PATCHES" ]]; then
        err "pve-mod is not installed (cannot find $APPLY_PATCHES).\nInstall it first: dpkg -i pve-mod_*.deb"
    fi

    # в”Җв”Җ Legacy installation check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if grep -qF '$res->{sensorsJSONOutput}' "$NODES_PM" 2>/dev/null || \
       grep -qF '$res->{systemInfo}' "$NODES_PM" 2>/dev/null; then
        err "A legacy pve-mod bash-script installation was detected in Nodes.pm.\nRemove it first:\n  bash /path/to/pve-mod-gui-sensors.sh uninstall"
    fi

    # в”Җв”Җ Initialize all config variables with safe defaults в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    MOD_NODE_INFO=0; MOD_NAG_SCREEN=0; PVE_TRIGGER_ENABLED=0
    node_info_defaults
    nag_screen_defaults
    _load_main_conf
    node_info_load_conf
    nag_screen_load_conf

    # в”Җв”Җ Module / feature selection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    # Existing settings are loaded above; the user picks ONE option to (re)configure
    # this run, and all other options retain their previously saved values.
    msgb "\n=== pve-mod Module Selection ==="
    echo "Available options (select one):"
    echo -e "  [1] Node Info   $(mod_status "$MOD_NODE_INFO") вҖ” sensor readings, GPU stats, UPS, system information"
    echo -e "  [2] Nag Screen  $(mod_status "$MOD_NAG_SCREEN") вҖ” remove Proxmox subscription nag screen"
    echo -e "  [3] Auto re-patch on PVE upgrade $(mod_status "$PVE_TRIGGER_ENABLED") вҖ” automatically re-apply patches when"
    echo    "                    pve-manager is upgraded"
    echo    "  [n] None / cancel"
    local modChoice selected_mod="" patching_needed=0
    modChoice=$(ask "Select an option (1/2/3/n)")
    case "$modChoice" in
        1)
            selected_mod="node_info"
            if [[ "$MOD_NODE_INFO" == "1" ]]; then
                MOD_NODE_INFO=0; info "Node Info will be removed."
            else
                MOD_NODE_INFO=1; patching_needed=1
                msgb "\n=== Node Info Configuration ==="
                node_info_configure
            fi
            ;;
        2)
            selected_mod="nag_screen"
            if [[ "$MOD_NAG_SCREEN" == "1" ]]; then
                MOD_NAG_SCREEN=0; info "Nag Screen will be removed."
            else
                MOD_NAG_SCREEN=1; patching_needed=1
                info "Subscription nag screen removal will be applied."
                nag_screen_configure
            fi
            ;;
        3)
            if [[ "$PVE_TRIGGER_ENABLED" == "1" ]]; then
                PVE_TRIGGER_ENABLED=0; info "Auto re-patch disabled."
            else
                PVE_TRIGGER_ENABLED=1; info "Auto re-patching on PVE upgrade enabled."
            fi
            ;;
        [nN]) info "No option selected. Exiting."; exit 0 ;;
        *)    warn "Invalid selection. Exiting."; exit 0 ;;
    esac

    # в”Җв”Җ Write config and apply/revert в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    # For mods with patches: apply if being enabled, revert if being disabled.
    # Option 3 (pve_trigger) has no patches вҖ” write_main_conf is sufficient.
    if [[ "$patching_needed" == "1" ]]; then
        msgb "\n=== Applying patches ==="
        if ! "$APPLY_PATCHES" "$selected_mod"; then
            err "Could not apply all patches for $selected_mod. Configuration was not updated."
        fi
    elif [[ -n "$selected_mod" ]]; then
        msgb "\n=== Removing patches ==="
        if ! "$REVERT_PATCHES" "$selected_mod"; then
            err "Could not revert all patches for $selected_mod. Configuration was not updated."
        fi
    fi
    write_main_conf
    node_info_write_conf
    nag_screen_write_conf

    msgb "\n=== Done ==="
    info "pve-mod is configured and active."
    info "Clear your browser cache to see the changes."
}

main
